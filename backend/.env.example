ANTHROPIC_API_KEY=your_key_here

# Optional — enables Supabase (Postgres) caching of computed analytics, AI
# evaluations, and the visualization payloads for much faster repeat responses.
# Leave both unset and the app still runs with zero setup, falling back to a
# local JSON-file cache. Use the SERVICE ROLE key (not the anon key): the
# backend writes to the cache tables, which are read-only for anon clients.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
